{
  "name": "trading-copilot",
  "version": "1.0.0",
  "description": "AI-powered day trading copilot with Alpaca integration",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.tradingcopilot.app",
    "productName": "Trading Copilot",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
