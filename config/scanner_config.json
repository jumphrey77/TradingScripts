{
  "$schema": "./scanner.schema.json",
  "appsettings": {
    "Debug": false,
    "DebugAPI": false,
    "DefaultTheme": "light",
    "OutputSymbolAnalysis": true,
    "UsePreMarketData": true
  },
  "finviz": {
    "avgvol": "o500",
    "change": "u",
    "curvol": "o50",
    "float": "",
    "ignoresectors": [
      ""
    ],
    "news": "sinceyesterday",
    "price": "u20",
    "relvol": "o2"
  },
  "scanner": {
    "atr": 8,
    "gap": 5,
    "price_max": 20,
    "price_min": 1,
    "relvol": 2,
    "score_min": 200
  },
  "simulator": {
    "bar_interval_default": "1m",
    "conflict_policy": "worst_case",
    "default_entry_mode": "limit",
    "enabled": true,
    "entry_fill_default": "mid",
    "max_recs_per_run": 55,
    "min_score_default": 400,
    "outcome_priority": [
      "STOP",
      "PCT",
      "T2",
      "T1"
    ],
    "profit_pct_default": 0.15,
    "session_end": "16:00",
    "session_start": "09:30",
    "use_stop_default": true
  }
}