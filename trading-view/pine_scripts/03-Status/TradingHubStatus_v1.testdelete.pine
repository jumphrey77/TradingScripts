// This source code is subject to the terms of the Mozilla Public License 2.0
// © TradingHubStatus | v1.2 | Generated by Claude (Anthropic)
//@version=6
strategy(
     title             = "TradingHubStatus v1.2 [Claude]",
     shorttitle        = "THStatus",
     overlay           = true,
     calc_on_every_tick= false,
     process_orders_on_close = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 0,
     commission_type   = strategy.commission.percent,
     commission_value  = 0)

// ═══════════════════════════════════════════════════════════════════
//  SETTINGS — General
// ═══════════════════════════════════════════════════════════════════
var string GRP_GEN = "⚙️ General"

targetEnv = input.string(
     "paper", "Environment",
     options = ["live", "paper"],
     tooltip = "Routes payload to live or paper backend. Your server reads this field.",
     group   = GRP_GEN)

delaySeconds = input.int(
     3, "Webhook Delay Hint (seconds)",
     minval  = 0, maxval = 60,
     tooltip = "Passed in payload as 'delay_seconds'. Your backend sleeps this long before processing.",
     group   = GRP_GEN)

webhookToken = input.string(
     "YOUR_SECRET_TOKEN", "Auth Token",
     tooltip = "Included as 'auth_token' in every payload. Validate server-side.",
     group   = GRP_GEN)

showPlots = input.bool(
     true, "Show Indicator Plots",
     tooltip = "Toggle all MA/VWAP lines on the chart. Uncheck to run with no drawings.",
     group   = GRP_GEN)

showLabel = input.bool(
     true, "Show Status Label",
     tooltip = "Toggle the status label on the chart.",
     group   = GRP_GEN)

// ═══════════════════════════════════════════════════════════════════
//  SETTINGS — Data Toggles
// ═══════════════════════════════════════════════════════════════════
var string GRP_DATA = "📦 Data Payload"

allowBasicData    = input.bool(true, "Allow Basic Data",     group=GRP_DATA, tooltip="Ticker, OHLCV, timestamps, timeframe, environment.")
allowIndicators   = input.bool(true, "Allow Indicator Data", group=GRP_DATA, tooltip="SMA, EMA, VWAP, ATR, BB, MACD, Volume stats.")
allowRSIFlags     = input.bool(true, "Allow RSI Flags",      group=GRP_DATA, tooltip="RSI value, MA, over50/70/80, under30.")
allowTrendFlags   = input.bool(true, "Allow Trend Flags",    group=GRP_DATA, tooltip="Price vs MAs, golden cross, EMA stack, BB position.")
allowSessionData  = input.bool(true, "Allow Session Data",   group=GRP_DATA, tooltip="isPremarket, isRegular, isAfterHours (US hours — reference only for crypto).")
allowPositionData = input.bool(true, "Allow Position Data",  group=GRP_DATA, tooltip="Simulated position state. Cross-ref Alpaca API server-side for live positions.")

// ═══════════════════════════════════════════════════════════════════
//  SETTINGS — Indicator Lengths
// ═══════════════════════════════════════════════════════════════════
var string GRP_IND = "📊 Indicator Parameters"

rsiLen     = input.int(14,   "RSI Length",        minval=2, group=GRP_IND)
rsiMaLen   = input.int(9,    "RSI MA Length",     minval=2, group=GRP_IND)
smaShort   = input.int(20,   "SMA Short (20)",    minval=2, group=GRP_IND)
smaLong    = input.int(200,  "SMA Long (200)",    minval=2, group=GRP_IND)
emaFast    = input.int(9,    "EMA Fast (9)",      minval=2, group=GRP_IND)
emaMid     = input.int(21,   "EMA Mid (21)",      minval=2, group=GRP_IND)
atrLen     = input.int(14,   "ATR Length",        minval=2, group=GRP_IND)
bbLen      = input.int(20,   "BB Length",         minval=2, group=GRP_IND)
bbMult     = input.float(2.0,"BB Multiplier",  minval=0.1, group=GRP_IND)
volAvgLen  = input.int(20,   "Volume MA Length",  minval=2, group=GRP_IND)
macdFast   = input.int(12,   "MACD Fast",         minval=2, group=GRP_IND)
macdSlow   = input.int(26,   "MACD Slow",         minval=2, group=GRP_IND)
macdSig    = input.int(9,    "MACD Signal",       minval=2, group=GRP_IND)

// ═══════════════════════════════════════════════════════════════════
//  CALCULATIONS
// ═══════════════════════════════════════════════════════════════════

sma20Val   = ta.sma(close, smaShort)
sma200Val  = ta.sma(close, smaLong)
ema9Val    = ta.ema(close, emaFast)
ema21Val   = ta.ema(close, emaMid)
vwapVal    = ta.vwap(hlc3)
rsiVal     = ta.rsi(close, rsiLen)
rsiMaVal   = ta.sma(rsiVal, rsiMaLen)
atrVal     = ta.atr(atrLen)

[bbUpper, bbBasis, bbLower] = ta.bb(close, bbLen, bbMult)
bbWidth    = (bbUpper - bbLower) / bbBasis * 100

[macdLine, macdSigLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)

volAvgVal  = ta.sma(volume, volAvgLen)
relVol     = volume / volAvgVal

// ── RSI Flags
isRSIOver50  = rsiVal > 50
isRSIOver70  = rsiVal > 70
isRSIOver80  = rsiVal > 80
isRSIUnder30 = rsiVal < 30
isRSIAboveMA = rsiVal > rsiMaVal

// ── Trend Flags
priceAboveSMA20  = close > sma20Val
priceAboveSMA200 = close > sma200Val
priceAboveVWAP   = close > vwapVal
priceAboveEMA9   = close > ema9Val
priceAboveEMA21  = close > ema21Val
isGoldenCross    = sma20Val > sma200Val
isDeathCross     = sma20Val < sma200Val
bullEMAStack     = ema9Val > ema21Val and ema21Val > sma20Val
priceAboveBBMid  = close > bbBasis
nearBBUpper      = close > (bbUpper - atrVal * 0.5)
nearBBLower      = close < (bbLower + atrVal * 0.5)
isBBSqueeze      = bbWidth < 5.0
macdBullish      = macdHist > 0

// ── Session
isPremarket  = hour < 9 or (hour == 9 and minute < 30)
isRegular    = (hour == 9 and minute >= 30) or (hour > 9 and hour < 16)
isAfterHours = hour >= 16 and hour < 20

// ── Position
posSize  = strategy.position_size
hasLong  = posSize > 0
hasShort = posSize < 0
isFlat   = posSize == 0
posDir   = hasLong ? "long" : hasShort ? "short" : "flat"

// ── Dummy entry to satisfy strategy requirement — never fires
if false
    strategy.entry("_", strategy.long)

fireAlert = barstate.isconfirmed

// ═══════════════════════════════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════════════════════════════

bstr(b) => b ? "true" : "false"
r4(v)   => str.tostring(math.round(v * 10000) / 10000)
ri(v)   => str.tostring(math.round(v))

// ═══════════════════════════════════════════════════════════════════
//  PAYLOAD BUILDER
// ═══════════════════════════════════════════════════════════════════

buildPayload() =>
    p = "{"
    p += '"script":"TradingHubStatus",'
    p += '"version":"1.2",'
    p += '"by":"Claude-Anthropic",'
    p += '"auth_token":"' + webhookToken + '",'
    p += '"environment":"' + targetEnv + '",'
    p += '"delay_seconds":' + str.tostring(delaySeconds) + ','
    p += '"alert_time_utc":"' + str.format_time(timenow, "yyyy-MM-dd HH:mm:ss", "UTC") + '",'
    p += '"bar_time_utc":"' + str.format_time(time, "yyyy-MM-dd HH:mm:ss", "UTC") + '",'
    p += '"timeframe":"' + timeframe.period + '",'
    p += '"ticker":"' + syminfo.ticker + '",'
    p += '"exchange":"' + syminfo.prefix + '",'
    p += '"currency":"' + syminfo.currency + '",'
    p += '"type":"' + syminfo.type + '",'

    if allowBasicData
        p += '"basic":{'
        p += '"open":' + r4(open) + ','
        p += '"high":' + r4(high) + ','
        p += '"low":' + r4(low) + ','
        p += '"close":' + r4(close) + ','
        p += '"volume":' + ri(volume) + ','
        p += '"change_pct":' + r4((close - open) / open * 100)
        p += '},'

    if allowIndicators
        p += '"indicators":{'
        p += '"sma20":' + r4(sma20Val) + ','
        p += '"sma200":' + r4(sma200Val) + ','
        p += '"ema9":' + r4(ema9Val) + ','
        p += '"ema21":' + r4(ema21Val) + ','
        p += '"vwap":' + r4(vwapVal) + ','
        p += '"rsi":' + r4(rsiVal) + ','
        p += '"rsi_ma":' + r4(rsiMaVal) + ','
        p += '"atr":' + r4(atrVal) + ','
        p += '"atr_pct":' + r4(atrVal / close * 100) + ','
        p += '"bb_upper":' + r4(bbUpper) + ','
        p += '"bb_lower":' + r4(bbLower) + ','
        p += '"bb_basis":' + r4(bbBasis) + ','
        p += '"bb_width_pct":' + r4(bbWidth) + ','
        p += '"macd_line":' + r4(macdLine) + ','
        p += '"macd_signal":' + r4(macdSigLine) + ','
        p += '"macd_hist":' + r4(macdHist) + ','
        p += '"macd_bullish":' + bstr(macdBullish) + ','
        p += '"volume":' + ri(volume) + ','
        p += '"volume_ma":' + ri(volAvgVal) + ','
        p += '"relative_volume":' + r4(relVol)
        p += '},'

    if allowRSIFlags
        p += '"rsi_flags":{'
        p += '"is_over_50":' + bstr(isRSIOver50) + ','
        p += '"is_over_70":' + bstr(isRSIOver70) + ','
        p += '"is_over_80":' + bstr(isRSIOver80) + ','
        p += '"is_under_30":' + bstr(isRSIUnder30) + ','
        p += '"rsi_above_ma":' + bstr(isRSIAboveMA)
        p += '},'

    if allowTrendFlags
        p += '"trend_flags":{'
        p += '"price_above_sma20":' + bstr(priceAboveSMA20) + ','
        p += '"price_above_sma200":' + bstr(priceAboveSMA200) + ','
        p += '"price_above_vwap":' + bstr(priceAboveVWAP) + ','
        p += '"price_above_ema9":' + bstr(priceAboveEMA9) + ','
        p += '"price_above_ema21":' + bstr(priceAboveEMA21) + ','
        p += '"golden_cross":' + bstr(isGoldenCross) + ','
        p += '"death_cross":' + bstr(isDeathCross) + ','
        p += '"bullish_ema_stack":' + bstr(bullEMAStack) + ','
        p += '"price_above_bb_mid":' + bstr(priceAboveBBMid) + ','
        p += '"near_bb_upper":' + bstr(nearBBUpper) + ','
        p += '"near_bb_lower":' + bstr(nearBBLower) + ','
        p += '"bb_squeeze":' + bstr(isBBSqueeze) + ','
        p += '"macd_bullish":' + bstr(macdBullish)
        p += '},'

    if allowSessionData
        p += '"session":{'
        p += '"is_premarket":' + bstr(isPremarket) + ','
        p += '"is_regular":' + bstr(isRegular) + ','
        p += '"is_afterhours":' + bstr(isAfterHours) + ','
        p += '"note":"Crypto is 24-7. Session flags are US-hours reference for stocks only."'
        p += '},'

    if allowPositionData
        p += '"position":{'
        p += '"size":' + r4(posSize) + ','
        p += '"direction":"' + posDir + '",'
        p += '"has_long":' + bstr(hasLong) + ','
        p += '"has_short":' + bstr(hasShort) + ','
        p += '"is_flat":' + bstr(isFlat) + ','
        p += '"note":"Simulated position only. Cross-ref Alpaca GET /v2/positions/{symbol} for live state."'
        p += '},'

    p += '"_end":true}'
    p

// ═══════════════════════════════════════════════════════════════════
//  FIRE ALERT
// ═══════════════════════════════════════════════════════════════════
if fireAlert
    alert(buildPayload(), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════
//  VISUALS — all gated by toggles
// ═══════════════════════════════════════════════════════════════════

// Plot colors go transparent (invisible) when showPlots is off
plotColor(c) => showPlots ? c : color.new(c, 100)

plot(sma20Val,  "SMA 20",  color=plotColor(color.orange), linewidth=1)
plot(sma200Val, "SMA 200", color=plotColor(color.red),    linewidth=2)
plot(ema9Val,   "EMA 9",   color=plotColor(color.lime),   linewidth=1)
plot(ema21Val,  "EMA 21",  color=plotColor(color.teal),   linewidth=1)
plot(vwapVal,   "VWAP",    color=plotColor(color.purple), linewidth=1)

// Status label — shows env prominently, gated by showLabel
if barstate.islast and showLabel
    envColor  = targetEnv == "live" ? color.new(color.red, 0) : color.new(color.blue, 0)
    envBadge  = targetEnv == "live" ? "🔴 LIVE" : "🔵 PAPER"
    crossTxt  = isGoldenCross ? "✦ Golden Cross" : "✦ Death Cross"
    lbl  = "THStatus v1.2  " + envBadge + "\n"
    lbl += syminfo.ticker + " | " + timeframe.period + " | +" + str.tostring(delaySeconds) + "s\n"
    lbl += "RSI: " + r4(rsiVal) + "  RelVol: " + r4(relVol) + "x\n"
    lbl += crossTxt
    label.new(bar_index, high,
         lbl,
         style     = label.style_label_lower_right,
         color     = envColor,
         textcolor = color.white,
         size      = size.small)
